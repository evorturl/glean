{
  "name": "glean",
  "version": "1.0.0",
  "description": "Glean coding exercise prototype",
  "private": true,
  "scripts": {
    "setup": "./scripts/setup.sh",
    "build": "tsc -p tsconfig.json",
    "clean": "./scripts/cleanup.sh",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --import tsx --test test/*.test.ts",
    "test:e2e": "tsx src/e2e.ts",
    "test": "npm run test:unit",
    "check": "npm run lint && npm run typecheck && npm run test:unit",
    "demo": "./scripts/demo.sh",
    "ingest": "tsx src/cli.ts ingest",
    "ask": "tsx src/cli.ts ask",
    "mcp": "tsx src/mcp.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evorturl/glean.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/evorturl/glean/issues"
  },
  "homepage": "https://github.com/evorturl/glean#readme",
  "dependencies": {
    "@gleanwork/api-client": "^0.14.14",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
