# Required for ingest and e2e/demo runs so indexed docs are visible.
GLEAN_ALLOWED_USER_EMAIL=reviewer@example.com

# Required for fixture ingestion.
GLEAN_INDEXING_API_TOKEN=replace-with-indexing-token

# Required for search retrieval.
GLEAN_SEARCH_API_TOKEN=replace-with-search-token

# Required for grounded answer generation.
GLEAN_CLIENT_API_TOKEN=replace-with-client-token

# Optional: needed when the client token is a global token.
# GLEAN_CLIENT_ACT_AS=reviewer@example.com

# Optional: used by GitHub and Linear automation in this repo.
# GH_TOKEN=replace-with-github-token
# LINEAR_API_KEY=replace-with-linear-api-key
