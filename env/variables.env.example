GLEAN_INSTANCE=support-lab
# Optional if you need to override the instance-derived backend URL.
# GLEAN_SERVER_URL=https://support-lab-be.glean.com

# Sandbox datasource family from the exercise brief.
GLEAN_DEFAULT_DATASOURCE=interviewds
GLEAN_DEFAULT_TOP_K=4

# Required for ingest visibility in the sandbox.
GLEAN_ALLOWED_USER_EMAIL=reviewer@example.com

# Optional: needed when the client token is a global token.
# GLEAN_CLIENT_ACT_AS=reviewer@example.com
